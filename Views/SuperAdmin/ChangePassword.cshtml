@model Taver.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change password";
}

<h2 class="mb-4">Change password</h2>
<p class="text-muted">User: <strong>@Model.UserEmail</strong></p>
<form asp-action="ChangePassword" method="post">
    <input type="hidden" asp-for="UserId" />
    <input type="hidden" asp-for="UserEmail" />
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="NewPassword" class="form-label"></label>
        <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="NewPassword" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ConfirmPassword" class="form-label"></label>
        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Change password</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
